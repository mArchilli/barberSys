APP_NAME=Pelito
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=America/Argentina/Buenos_Aires

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_AR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# En producción: LOG_CHANNEL=daily (rotación automática) y LOG_LEVEL=warning
# o superior — 'debug'/'single' son para desarrollo local. Ver DEPLOYMENT.md.
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Reporte de errores externo (opcional, no instalado todavía — ver DEPLOYMENT.md)
# SENTRY_LARAVEL_DSN=

# Local: sqlite alcanza para desarrollar sin instalar MySQL.
# Producción: DB_CONNECTION=mysql + el resto de las DB_* de abajo (ver DEPLOYMENT.md).
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Integraciones externas ---------------------------------------------
# Pasar de test a producción es SOLO cambiar estas variables — cero código.

# MercadoPago Suscripciones (preapproval) — usar credenciales TEST- en
# desarrollo y APP_USR- en producción. El sistema detecta el modo
# automáticamente por el prefijo del token (visible en Admin > Salud técnica).
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
# URL pública que recibe las notificaciones de MP (POST /webhooks/mercadopago).
# En producción: https://tudominio.com/webhooks/mercadopago
MERCADOPAGO_WEBHOOK_URL=

# Opcional, SOLO desarrollo local detrás de un túnel (ej. ngrok): dominio
# público desde el que MercadoPago puede alcanzar la app para el back_url del
# checkout (MP rechaza "localhost"). NO reemplaza APP_URL ni afecta cómo el
# resto de la app genera sus rutas — dejar vacío en producción (ahí APP_URL
# ya es el dominio público real y alcanza).
# APP_PUBLIC_URL=https://tu-subdominio.ngrok-free.dev

# Facturante (facturación electrónica) — dejar vacío para operar sin
# facturación automática (modo NullInvoicingService, fallback silencioso).
FACTURANTE_API_KEY=

# WhatsApp (patrón wa.me, sin API de WhatsApp Business): código de país +
# número, SIN espacios ni el símbolo +, ej. 5491122334455 para Argentina. Es
# el formato que exige wa.me — con espacios o "+" el link no abre el chat.
# Soporte (owner ya activo pidiendo ayuda) y ventas (prospecto en la landing
# preguntando por un plan) son casos de uso distintos y pueden terminar en
# números diferentes el día de mañana — separadas aunque hoy tengan el mismo
# valor.
WHATSAPP_SUPPORT_NUMBER=
WHATSAPP_SALES_NUMBER=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
